# ================================================
# .env.example — Plantilla de variables de entorno
# ================================================
# Copia este archivo como .env y rellena los valores reales.
# NUNCA subas el archivo .env al repositorio.
# cp .env.example .env

# ------------------------------------------------
# SERVIDOR
# ------------------------------------------------

# Puerto en el que arranca el servidor (por defecto 3000)
PORT=3000

# ------------------------------------------------
# BASE DE DATOS
# ------------------------------------------------

# URI de conexión a MongoDB
# Desarrollo local:
#   MONGO_URI=mongodb://localhost:27017/mini-siem
# Producción (MongoDB Atlas):
#   MONGO_URI=mongodb+srv://<usuario>:<password>@<cluster>.mongodb.net/<dbname>?retryWrites=true&w=majority
MONGO_URI=mongodb://localhost:27017/mini-siem

# ------------------------------------------------
# AUTENTICACIÓN JWT (NO IMPLEMENTADO)
# ------------------------------------------------

# Clave secreta para firmar los tokens JWT (futuro)
# JWT_SECRET=cambia_esto_por_una_clave_secreta_segura

# Tiempo de expiración del token (futuro)
# JWT_EXPIRES_IN=24h

# ------------------------------------------------
# ENTORNO
# ------------------------------------------------

# Entorno de ejecución: development | production | test
NODE_ENV=development
