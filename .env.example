# ════════════════════════════════════════════════════════════════════════════════
# MINI-SIEM PERSONAL — Configuración de variables de entorno
# 
# COPIAR A .env Y RELLENAR LOS VALORES ANTES DE EJECUTAR EN PRODUCCIÓN
# ════════════════════════════════════════════════════════════════════════════════

# Entorno: 'development' o 'production'
NODE_ENV=development

# Servidor
PORT=3000

# Base de datos MongoDB
# Desarrollo local:
#   MONGO_URI=mongodb://localhost:27017/mini-siem
# Producción (MongoDB Atlas):
#   MONGO_URI=mongodb+srv://<usuario>:<password>@<cluster>.mongodb.net/<dbname>?retryWrites=true&w=majority
MONGO_URI=mongodb://localhost:27017/mini-siem

# CORS - URL del frontend en producción (para CORS)
FRONTEND_URL=https://tu-app-en-render.onrender.com

# ════════════════════════════════════════════════════════════════════════════════
# AUTENTICACIÓN JWT — CRÍTICO: CAMBIAR EN PRODUCCIÓN
# ════════════════════════════════════════════════════════════════════════════════

# Clave secreta para firmar los tokens JWT
# ⚠️ CAMBIAR EN PRODUCCIÓN A UN VALOR SEGURO Y ALEATORIO
# Generar: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=tu-secreto-jwt-aleatorio-y-super-seguro-32-caracteres-minimo-CAMBIAR

# Tiempo de expiración del token JWT (8 horas en desarrollo, 1h en producción recomendado)
JWT_EXPIRES_IN=8h

# ════════════════════════════════════════════════════════════════════════════════
# CREDENCIALES DE ADMINISTRADOR — CRÍTICO: CAMBIAR EN PRODUCCIÓN
# ════════════════════════════════════════════════════════════════════════════════

# Usuario del administrador
ADMIN_USER=admin

# Hash de contraseña bcrypt del administrador
# ⚠️ CAMBIAR EN PRODUCCIÓN
# Generar hash seguro:
#   1. Elige una contraseña fuerte (mín 12 caracteres con mayús, minús, números, símbolos)
#   2. Ejecuta: node -e "require('bcryptjs').hash('TU_PASSWORD_FUERTE_AQUI',10).then(console.log)"
#   3. Copia el hash generado aquí
ADMIN_HASH=$2a$10$TU_HASH_BCRYPT_GENERADO_AQUI
