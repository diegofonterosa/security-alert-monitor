# ================================================
# .env.example — Plantilla de variables de entorno
# ================================================
# Copia este archivo como .env y rellena los valores reales.
# NUNCA subas el archivo .env al repositorio.
# cp .env.example .env

# ------------------------------------------------
# SERVIDOR
# ------------------------------------------------

# Puerto en el que arranca el servidor (por defecto 3000)
PORT=3000

# ------------------------------------------------
# BASE DE DATOS
# ------------------------------------------------

# URI de conexion a MongoDB
# Desarrollo local:
# MONGO_URI=mongodb://localhost:27017/mini-siem
# Produccion (MongoDB Atlas):
# MONGO_URI=mongodb+srv://<usuario>:<password>@<cluster>.mongodb.net/<dbname>?retryWrites=true&w=majority
MONGO_URI=mongodb://localhost:27017/mini-siem

# URL del frontend en produccion (para CORS)
FRONTEND_URL=https://tu-app-en-render.onrender.com

# ------------------------------------------------
# AUTENTICACION JWT
# ------------------------------------------------

# Clave secreta para firmar los tokens JWT (cambia esto en produccion)
JWT_SECRET=tu-secreto-jwt-super-seguro-cambiar-en-produccion

# Tiempo de expiracion del token
JWT_EXPIRES_IN=8h

# ------------------------------------------------
# CREDENCIALES DE ADMINISTRADOR
# ------------------------------------------------

# Usuario administrador (nombre de usuario para el login)
ADMIN_USER=admin

# Hash bcrypt de la contrasena del administrador
# Para generar el hash ejecuta:
#   node -e "require('bcryptjs').hash('TU_PASSWORD', 10).then(console.log)"
# Luego pega el resultado aqui:
ADMIN_HASH=$2b$10$REEMPLAZA_CON_TU_HASH_BCRYPT_GENERADO

# ------------------------------------------------
# ENTORNO
# ------------------------------------------------

# Entorno de ejecucion: development | production | test
NODE_ENV=development
